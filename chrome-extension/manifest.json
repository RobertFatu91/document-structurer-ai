{
  "manifest_version": 3,
  "name": "Document Structurer AI",
  "version": "1.0.0",
  "description": "Turn messy email drafts into professional client-ready text.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://document-structurer-ai.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}