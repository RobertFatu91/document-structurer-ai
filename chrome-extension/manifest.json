{
  "manifest_version": 3,
  "name": "Smart Reply AI for Gmail",
  "version": "1.0.0",
  "description": "Generate professional email replies directly inside Gmail.",
  "icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
},


  "host_permissions": [
    "https://mail.google.com/*",
    "https://document-structurer-ai.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
    "action": {
  "default_title": "Smart Reply AI for Gmail"
},

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}